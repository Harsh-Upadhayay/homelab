OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw
OPENCLAW_TAG=latest
OPENCLAW_LOCAL_IMAGE=homelab/openclaw

OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_DISABLE_BONJOUR=1
OPENCLAW_BOOTSTRAP_BROWSER_CONFIG=1

OPENCLAW_CONFIG_DIR=${HOMELAB_STORAGE_ROOT}/openclaw/config
OPENCLAW_WORKSPACE_DIR=${HOMELAB_STORAGE_ROOT}/openclaw/workspace

# Use a headed Chromium inside a virtual display by default. Set this to
# host and mount /tmp/.X11-unix if you want windows on the host X display.
OPENCLAW_BROWSER_DISPLAY_MODE=xvfb
OPENCLAW_BROWSER_DISPLAY=:99
OPENCLAW_XVFB_SCREEN=1920x1080x24
OPENCLAW_BROWSER_HEADLESS=0
PLAYWRIGHT_BROWSERS_PATH=/home/node/.cache/ms-playwright
