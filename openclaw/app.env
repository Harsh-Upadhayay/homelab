# Image
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw
OPENCLAW_TAG=latest

# Gateway
OPENCLAW_HOST=openclaw.${HOMELAB_DOMAIN}
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_CONTROL_UI_DISABLE_DEVICE_AUTH=true

# Browser
OPENCLAW_BROWSER_PROFILE=openclaw
OPENCLAW_BROWSER_DEBUG_PORT=9222
OPENCLAW_BROWSER_HOST_DEBUG_PORT=19223
OPENCLAW_BROWSER_CDP_URL=http://openclaw-browser-proxy:9223
OPENCLAW_BROWSER_COLOR=#FF9900

# Models
OPENCLAW_DEFAULT_MODEL=deepseek/deepseek-chat
OPENCLAW_FALLBACK_MODEL=deepseek/deepseek-reasoner

# Skills and integrations
OPENCLAW_SKILL_SYNC_INTERVAL_SECONDS=60
CAREERFLOW_API_URL=http://careerflow-api:8000

# Persistent storage
OPENCLAW_CONFIG_DIR=${HOMELAB_STORAGE_ROOT}/openclaw/config
OPENCLAW_WORKSPACE_DIR=${HOMELAB_STORAGE_ROOT}/openclaw/workspace
