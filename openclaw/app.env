OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw
OPENCLAW_TAG=latest

OPENCLAW_HOST=openclaw.${HOMELAB_DOMAIN}
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_CONTROL_UI_DISABLE_DEVICE_AUTH=true

OPENCLAW_CONFIG_DIR=${HOMELAB_STORAGE_ROOT}/openclaw/config
OPENCLAW_WORKSPACE_DIR=${HOMELAB_STORAGE_ROOT}/openclaw/workspace
