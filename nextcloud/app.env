NEXTCLOUD_IMAGE=nextcloud
# Keep this aligned with /var/www/html/version.php; do not track nextcloud:latest.
NEXTCLOUD_TAG=31.0.8-apache

NEXTCLOUD_DB_IMAGE=postgres
NEXTCLOUD_DB_TAG=16-alpine

NEXTCLOUD_REDIS_IMAGE=redis
NEXTCLOUD_REDIS_TAG=alpine

NEXTCLOUD_DB_NAME=nextcloud
NEXTCLOUD_DB_USER=nextcloud
NEXTCLOUD_DB_HOST=nextcloud-db
NEXTCLOUD_REDIS_HOST=nextcloud-redis
NEXTCLOUD_APP_LOCATION=${HOMELAB_STORAGE_ROOT}/nextcloud/app
NEXTCLOUD_DB_DATA_LOCATION=${HOMELAB_STORAGE_ROOT}/nextcloud/postgres
