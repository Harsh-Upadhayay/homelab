# ---- pinned image versions (upgrade intentionally; see ops/upgrade-checklist.md) ----
PROWLARR_IMAGE=lscr.io/linuxserver/prowlarr
PROWLARR_TAG=2.0.5.5160-ls125
SONARR_IMAGE=lscr.io/linuxserver/sonarr
SONARR_TAG=4.0.15.2941-ls291
RADARR_IMAGE=lscr.io/linuxserver/radarr
RADARR_TAG=5.27.5.10198-ls282
JELLYFIN_IMAGE=lscr.io/linuxserver/jellyfin
JELLYFIN_TAG=10.11.0ubu2404-ls4
JELLYSEERR_IMAGE=fallenbagel/jellyseerr
JELLYSEERR_TAG=2.7.3
QBIT_IMAGE=lscr.io/linuxserver/qbittorrent
QBIT_TAG=5.1.2-r2-ls415
GLUETUN_IMAGE=ghcr.io/qdm12/gluetun
GLUETUN_TAG=v3.41.1
FLARESOLVERR_IMAGE=ghcr.io/flaresolverr/flaresolverr
FLARESOLVERR_TAG=v3.4.0

# ---- run defaults ----
TZ=Asia/Tokyo
PUID=1000
PGID=1000

# qBittorrent UI port *inside* container (Traefik hits it through Gluetun)
QBIT_WEBUI_PORT=8080
MEDIASERVER_DATA_ROOT=${HOMELAB_STORAGE_ROOT}/mediaserver
MEDIASERVER_STATE_ROOT=${HOMELAB_STORAGE_ROOT}/mediaserver/state
